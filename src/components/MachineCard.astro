---
export interface Props {
  brand: string;
  model: string;
  year: number;
  hours: number;
  price_cny: number;
  location: string;
  status: string;
  cover_image: string;
  slug: string;
}

const { brand, model, year, hours, price_cny, location, status, cover_image, slug } = Astro.props;
const base = import.meta.env.BASE_URL || '';
const statusLabel = { available: '在售', reserved: '已预定', sold: '已售' }[status] || status;
const priceFormatted = price_cny >= 10000
  ? `${(price_cny / 10000).toFixed(1)}万`
  : `¥${price_cny.toLocaleString()}`;
---

  <a href={`${base}machines/${slug}`} class="machine-card fade-in">
  <div class="card-image dark-image-wrap">
    <img src={`${base}${(cover_image || 'images/placeholder.svg').replace(/^\//, '')}`} alt={`${brand} ${model}`} loading="lazy" />
    <span class={`status-badge status-${status}`}>{statusLabel}</span>
  </div>
  <div class="card-body">
    <h3 class="card-title">{brand} {model}</h3>
    <div class="card-specs">
      <div class="spec">
        <span class="spec-label">年份</span>
        <span class="spec-value">{year}</span>
      </div>
      <div class="spec">
        <span class="spec-label">工时</span>
        <span class="spec-value">{hours.toLocaleString()}h</span>
      </div>
      <div class="spec">
        <span class="spec-label">地区</span>
        <span class="spec-value">{location}</span>
      </div>
      <div class="spec">
        <span class="spec-label">价格</span>
        <span class="spec-value price">{priceFormatted}</span>
      </div>
    </div>
  </div>
</a>

<style>
  .machine-card {
    display: block;
    background: var(--color-bg-card);
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: border-color 0.3s, transform 0.3s;
    cursor: pointer;
  }

  .machine-card:hover {
    border-color: var(--color-border-light);
    transform: translateY(-4px);
  }

  .card-image {
    position: relative;
    aspect-ratio: 16 / 10;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-image .status-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 1;
  }

  .card-body {
    padding: 16px;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 12px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .spec {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .spec-label {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .spec-value {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .spec-value.price {
    color: var(--color-accent);
    font-weight: 600;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FadeIn from '../components/FadeIn.astro';
import siteData from '../content/site.json';

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

// 首页大图 / 主张：来自 site.json，未来可由 Decap 后台「网站设置」控制
const heroImage = siteData.hero_image || 'images/Homepage-Card-Model-3-Desktop-CN-v2.jpg';
const heroHeadline = siteData.hero_headline || '二手工程机械<br/>品质优选 · 全国直发';
const heroSubheadline =
  siteData.hero_subheadline || '数百台卡特、小松、日立、神钢等品牌二手挖机，品质保障，价格透明';

// 精选设备：直接读取 CMS 内容目录（machines/*.md 中 featured:true 的条目）。
// 现在目录为空 → 这部分自动跳过；以后在后台上架并勾选「首页推荐」即出现。
// 目录为空时 Astro.glob 会抛错，这里用 try/catch 兜底，保证构建不中断。
let machineFiles = [];
try {
  machineFiles = await Astro.glob('../content/machines/*.{md,mdx}');
} catch {
  machineFiles = [];
}
const featured = machineFiles
  .map((f) => ({ ...f.frontmatter, url: f.url }))
  .filter((m) => m && m.featured)
  .slice(0, 3);

// 中间两张并排促销卡（复刻特斯拉官网中部双图布局），使用你提供的演示图。
// 以后可改为从 CMS 读取「品类」集合。
const promoCards = [
  {
    image: 'images/Homepage-Promo-Model-3-Y-Desktop-CN-v3.jpg',
    title: '二手挖掘机',
    subtitle: '卡特 · 小松 · 日立 · 神钢',
    primaryLink: `${base}machines`,
    outlineLink: `${base}contact`,
  },
  {
    image: 'images/Homepage-Card-Model-Y-Desktop-CN-v4.jpg',
    title: '二手装载机',
    subtitle: '主流品牌 · 成色优选',
    primaryLink: `${base}machines`,
    outlineLink: `${base}contact`,
  },
];
---

<BaseLayout title="首页" transparentHeader={true}>
  <!-- 1. 全屏主视觉 -->
  <Hero
    image={heroImage}
    headline={heroHeadline}
    subheadline={heroSubheadline}
    primaryText="浏览设备库"
    primaryLink="machines"
    outlineText="联系顾问"
    outlineLink="contact"
  />

  <!-- 2. 精选设备：CMS 驱动的全屏面板（目录空时自动隐藏） -->
  {
    featured.map((m) => (
      <section class="panel">
        <img
          class="panel-bg"
          src={base + (m.cover_image || 'images/placeholder.svg').replace(/^\//, '')}
          alt={`${m.brand} ${m.model}`}
        />
        <div class="panel-scrim" />
        <div class="panel-top fade-in">
          <h2 class="panel-title">{m.brand} {m.model}</h2>
          <p class="panel-meta">
            {m.year} 年 · {m.hours} 小时 · {m.location} · {m.price_cny} 元
          </p>
        </div>
        <div class="panel-actions fade-in">
          <a class="btn btn-primary btn-lg" href={m.url || `${base}machines`}>查看详情</a>
          <a class="btn btn-ghost btn-lg" href={`${base}contact`}>立即询价</a>
        </div>
      </section>
    ))
  }

  <!-- 3. 中间两张并排促销卡（特斯拉风格） -->
  <section class="promo-grid">
    {
      promoCards.map((c) => (
        <section class="promo-card fade-in">
          <img class="promo-bg" src={base + c.image.replace(/^\//, '')} alt={c.title} />
          <div class="promo-scrim" />
          <div class="promo-top">
            <h3 class="promo-title">{c.title}</h3>
            <p class="promo-sub">{c.subtitle}</p>
          </div>
          <div class="promo-actions">
            <a class="btn btn-primary btn-lg" href={c.primaryLink}>查看设备</a>
            <a class="btn btn-ghost btn-lg" href={c.outlineLink}>联系顾问</a>
          </div>
        </section>
      ))
    }
  </section>

  <!-- 4. 咨询 CTA（明亮浅色区块） -->
  <section class="cta-strip">
    <FadeIn>
      <div class="cta-inner">
        <h2 class="cta-title">找不到心仪的设备？</h2>
        <p class="cta-desc">告诉我们您的需求，全国范围帮您找车</p>
        <div class="cta-actions">
          <a class="btn btn-primary btn-lg" href={`${base}contact`}>立即咨询</a>
          <a class="btn btn-outline btn-lg" href={`${base}machines`}>浏览设备库</a>
        </div>
      </div>
    </FadeIn>
  </section>
</BaseLayout>

<style>
  /* 精选设备全屏面板 */
  .panel {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .panel-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .panel-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.12) 0%,
      rgba(0, 0, 0, 0) 35%,
      rgba(0, 0, 0, 0) 55%,
      rgba(0, 0, 0, 0.32) 100%
    );
  }

  .panel-top {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-top: 13vh;
    color: #fff;
    padding: 0 24px;
  }

  .panel-title {
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
  }

  .panel-meta {
    margin-top: 12px;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.3);
  }

  .panel-actions {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: auto;
    margin-bottom: 7vh;
  }

  /* 中间两张并排卡片 */
  .promo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }

  .promo-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 88vh;
    overflow: hidden;
    color: #fff;
  }

  .promo-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.6s ease;
  }

  .promo-card:hover .promo-bg {
    transform: scale(1.04);
  }

  .promo-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.16) 0%,
      rgba(0, 0, 0, 0) 30%,
      rgba(0, 0, 0, 0) 50%,
      rgba(0, 0, 0, 0.38) 100%
    );
  }

  .promo-top {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-top: 10vh;
    padding: 0 24px;
  }

  .promo-title {
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.25);
  }

  .promo-sub {
    margin-top: 10px;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.3);
  }

  .promo-actions {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: auto;
    margin-bottom: 8vh;
  }

  /* 咨询 CTA：明亮浅色区块 */
  .cta-strip {
    background: var(--color-bg);
    padding: 110px 0;
    text-align: center;
  }

  .cta-title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .cta-desc {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-bottom: 36px;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .promo-grid {
      grid-template-columns: 1fr;
    }
    .promo-card {
      min-height: 70vh;
    }
  }
</style>

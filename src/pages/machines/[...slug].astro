---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButtons from '../../components/CTAButtons.astro';
import { marked } from 'marked';

export async function getStaticPaths() {
  // 读取 Decap CMS 发布的真实设备（src/data/machines/*.md）。
  let entries = [];
  try {
    entries = await Astro.glob('../../data/machines/*.md');
  } catch (e) {
    entries = [];
  }
  return entries.map((m) => {
    const slug = (m.file || '').split(/[\\/]/).pop().replace(/\.md$/, '');
    const fm = m.frontmatter || {};
    return {
      params: { slug },
      props: {
        brand: fm.brand,
        model: fm.model,
        year: fm.year,
        hours: fm.hours,
        price_cny: fm.price_cny,
        location: fm.location,
        status: fm.status || 'available',
        description: fm.description || '',
        cover_image: fm.cover_image || '',
        gallery: fm.gallery || [],
      },
    };
  });
}

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const { brand, model, year, hours, price_cny, location, status, description, cover_image, gallery } = Astro.props;

// 设备描述是 markdown 字段（存于 frontmatter），需用 marked 渲染；
// 同时把其中的 /images/... 图片地址补上 base 前缀，避免子路径 404。
const descHtmlRaw = marked.parse(description || '');
function withBase(html) {
  const b = base.replace(/\/$/, '');
  return html.replace(/(src|href)="\/(?!vexilon)([^\/][^"]*)"/g, `$1="${b}/$2`);
}
const descHtml = withBase(descHtmlRaw);
const statusLabel = { available: '在售', reserved: '已预定', sold: '已售' }[status] || status;
const priceFormatted = price_cny >= 10000 ? `¥${(price_cny / 10000).toFixed(1)}万` : `¥${price_cny.toLocaleString()}`;
---

<BaseLayout title={`${brand} ${model}`}>
  <div class="detail-hero dark-image-wrap">
    <img src={`${base}${(cover_image || 'images/placeholder.svg').replace(/^\//, '')}`} alt={`${brand} ${model}`} />
    <div class="detail-hero-overlay"></div>
    <div class="detail-hero-content container">
      <div class="breadcrumb">
        <a href={`${base}machines`}>设备库</a> / <span>{brand} {model}</span>
      </div>
      <h1 class="detail-title">{brand} {model}</h1>
      <span class={`status-badge status-${status}`}>{statusLabel}</span>
    </div>
  </div>

  <div class="section">
    <div class="container">
      <div class="detail-grid">
        <div class="detail-main">
          <div class="specs-panel">
            <div class="spec-item">
              <span class="spec-label">品牌</span>
              <span class="spec-value">{brand}</span>
            </div>
            <div class="spec-item">
              <span class="spec-label">型号</span>
              <span class="spec-value">{model}</span>
            </div>
            <div class="spec-item">
              <span class="spec-label">出厂年份</span>
              <span class="spec-value">{year}</span>
            </div>
            <div class="spec-item">
              <span class="spec-label">工作小时</span>
              <span class="spec-value">{hours.toLocaleString()} h</span>
            </div>
            <div class="spec-item">
              <span class="spec-label">所在地区</span>
              <span class="spec-value">{location}</span>
            </div>
            <div class="spec-item">
              <span class="spec-label">价格</span>
              <span class="spec-value price">{priceFormatted}</span>
            </div>
          </div>

          <div class="description" set:html={descHtml}></div>
        </div>

        <div class="detail-sidebar">
          <div class="sidebar-sticky">
            <div class="sidebar-card">
              <div class="sidebar-price">{priceFormatted}</div>
              <p class="sidebar-status">状态：<span class={`status-badge status-${status}`}>{statusLabel}</span></p>
              <hr class="sidebar-divider" />
              <a href={`${base}contact`} class="btn btn-primary" style="width:100%">询价咨询</a>
              <a href={`${base}machines`} class="btn btn-outline" style="width:100%;margin-top:12px">浏览更多</a>
            </div>
          </div>
        </div>
      </div>

      {gallery && gallery.length > 1 && (
        <div class="gallery-section">
          <h2 class="section-title">更多照片</h2>
          <div class="gallery-grid">
            {gallery.map((img) => (
              <div class="gallery-item dark-image-wrap">
                <img src={`${base}${img.replace(/^\//, '')}`} alt="" loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .detail-hero {
    position: relative;
    height: 50vh;
    min-height: 400px;
    display: flex;
    align-items: flex-end;
  }

  .detail-hero img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .detail-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.8) 100%);
  }

  .detail-hero-content {
    position: relative;
    z-index: 1;
    padding-bottom: 48px;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }

  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-text); }

  .detail-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 48px;
  }

  .specs-panel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 40px;
  }

  .spec-item {
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
  }

  .spec-item:nth-child(even) { border-right: none; }

  .spec-item .spec-label {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 4px;
  }

  .spec-item .spec-value {
    font-size: 1.05rem;
    font-weight: 500;
  }

  .spec-item .spec-value.price {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 1.15rem;
  }

  .description {
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .description h2 {
    font-size: 1.3rem;
    color: var(--color-text);
    margin: 32px 0 12px;
    font-weight: 600;
  }

  .description ul {
    padding-left: 20px;
    margin: 12px 0;
  }

  .description li {
    margin-bottom: 8px;
  }

  .sidebar-sticky {
    position: sticky;
    top: 80px;
  }

  .sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 24px;
  }

  .sidebar-price {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 12px;
  }

  .sidebar-status { font-size: 0.9rem; color: var(--color-text-muted); margin-bottom: 0; }

  .sidebar-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 20px 0;
  }

  .gallery-section { margin-top: 64px; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 24px;
  }

  .gallery-item {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .detail-grid { grid-template-columns: 1fr; }
    .specs-panel { grid-template-columns: 1fr; }
    .spec-item:nth-child(even) { border-right: 1px solid var(--color-border); }
    .gallery-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

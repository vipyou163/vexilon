---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MachineCard from '../../components/MachineCard.astro';
import FilterBar from '../../components/FilterBar.astro';

// 读取 Decap CMS 发布的真实设备（src/data/machines/*.md）。
// 注意：不能放在 src/content/ 下，Astro 会把该目录预留给 Content Collections，
// 导致 glob 扫不到 .md 文件。
let allMachines = [];
try {
  const entries = await Astro.glob('../../data/machines/*.md');
  allMachines = entries.map((m) => {
    const slug = (m.file || '').split(/[\\/]/).pop().replace(/\.md$/, '');
    const fm = m.frontmatter || {};
    return {
      slug,
      brand: fm.brand,
      model: fm.model,
      year: fm.year,
      hours: fm.hours,
      price_cny: fm.price_cny,
      location: fm.location,
      status: fm.status || 'available',
      cover_image: fm.cover_image || '',
    };
  }).filter((m) => m.brand);
} catch (e) {
  allMachines = [];
}

// Filter logic
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const brands = [...new Set(allMachines.map(m => m.brand))];
const locations = [...new Set(allMachines.map(m => m.location))];

// Read URL params for filter
function getMachines() {
  let result = [...allMachines];
  const params = Astro.url.searchParams;
  const brand = params.get('brand');
  const location = params.get('location');
  const status = params.get('status');
  const sort = params.get('sort');

  if (brand) result = result.filter(m => m.brand === brand);
  if (location) result = result.filter(m => m.location === location);
  if (status) result = result.filter(m => m.status === status);

  if (sort === 'price-asc') result.sort((a, b) => a.price_cny - b.price_cny);
  else if (sort === 'price-desc') result.sort((a, b) => b.price_cny - a.price_cny);
  else if (sort === 'year-desc') result.sort((a, b) => b.year - a.year);
  else if (sort === 'hours-asc') result.sort((a, b) => a.hours - b.hours);

  return result;
}

const machines = getMachines();
---

<BaseLayout title="设备库">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-title fade-in">设备库</h1>
      <p class="page-desc fade-in">浏览我们精选的二手工程机械设备，真实车况，品质保障</p>
    </div>
  </section>

  <section class="section listing-section">
    <div class="container">
      <FilterBar brands={brands} locations={locations} />
      {machines.length > 0 ? (
        <div class="grid-3">
          {machines.map((m) => <MachineCard {...m} />)}
        </div>
      ) : (
        <div class="empty-state">
          <p>暂无设备，请到 Decap 后台「二手设备」添加</p>
          <a href={`${base}machines`} class="btn btn-outline" style="margin-top:16px">刷新</a>
        </div>
      )}
      <div class="count-info">
        共 <strong>{machines.length}</strong> 台设备
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 120px 0 48px;
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
  }

  .page-desc {
    color: var(--color-text-muted);
    margin-top: 12px;
    font-size: 1.05rem;
  }

  .listing-section { padding-top: 40px; }

  .empty-state {
    text-align: center;
    padding: 64px 0;
    color: var(--color-text-muted);
  }

  .count-info {
    margin-top: 32px;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-dim);
  }
</style>

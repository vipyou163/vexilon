---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  let entries = [];
  try {
    entries = await Astro.glob('../../data/posts/*.md');
  } catch (e) {
    entries = [];
  }
  return entries.map((p) => ({
    params: { slug: (p.file || '').split(/[\\/]/).pop().replace(/\.md$/, '') },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const { Content, frontmatter } = entry;
const fm = frontmatter || {};
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const cover = (fm.cover || '').replace(/^\//, '');
---

<BaseLayout title={fm.title}>
  <article class="post-article section">
    <div class="container">
      <div class="post-header">
        <div class="breadcrumb">
          <a href={`${base}posts`}>行业资讯</a> / <span>{fm.title}</span>
        </div>
        <h1 class="post-title">{fm.title}</h1>
        {fm.date && <time class="post-date">{fm.date}</time>}
      </div>

      {cover && (
        <div class="post-cover dark-image-wrap">
          <img src={`${base}${cover}`} alt={fm.title} />
        </div>
      )}

      <div class="post-body"><Content /></div>

      <div class="post-footer">
        <a href={`${base}posts`} class="btn btn-outline">← 返回资讯列表</a>
        <a href={`${base}contact`} class="btn btn-primary">联系我们</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-article { padding-top: 120px; }

  .post-header {
    margin-bottom: 32px;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }

  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-text); }

  .post-title {
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .post-date {
    font-size: 0.9rem;
    color: var(--color-text-dim);
  }

  .post-cover {
    aspect-ratio: 16 / 7;
    border-radius: var(--radius-md);
    margin-bottom: 48px;
  }

  .post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-body {
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.9;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .post-body h2 {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 48px 0 16px;
  }

  .post-body p {
    margin-bottom: 16px;
  }

  .post-body ul, .post-body ol {
    padding-left: 24px;
    margin: 16px 0;
  }

  .post-body li {
    margin-bottom: 8px;
  }

  .post-footer {
    max-width: 720px;
    margin: 64px auto 0;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: 16px;
    justify-content: space-between;
  }
</style>

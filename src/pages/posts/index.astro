---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

// 读取 Decap CMS 发布的真实文章（src/data/posts/*.md），按日期倒序。
// 注意：不能放在 src/content/ 下，Astro 会把该目录预留给 Content Collections，
// 导致 import.meta.glob / Astro.glob 扫不到文件。放在 src/data/ 即可正常 glob。
let posts = [];
try {
  const all = await Astro.glob('../../data/posts/*.md');
  posts = all
    .map((p) => {
      const raw = (p.rawContent ? p.rawContent() : '')
        .replace(/[#>*`\-]/g, ' ').replace(/\s+/g, ' ').trim();
      const slug = (p.file || '').split(/[\\/]/).pop().replace(/\.md$/, '');
      return {
        title: p.frontmatter?.title,
        date: p.frontmatter?.date,
        cover: p.frontmatter?.cover || '',
        slug,
        summary: raw.slice(0, 80) + (raw.length > 80 ? '…' : ''),
      };
    })
    .filter((p) => p.title)
    .sort((a, b) => new Date(b.date || 0) - new Date(a.date || 0));
} catch (e) {
  posts = [];
}
---

<BaseLayout title="行业资讯">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-title fade-in">行业资讯</h1>
      <p class="page-desc fade-in">二手工程机械行业动态、选购指南、保养知识</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="posts-list">
        {posts.map((post) => (
          <a href={`${base}posts/${post.slug}`} class="post-card fade-in">
            <div class="post-card-image dark-image-wrap">
              <img src={`${base}${(post.cover || 'images/placeholder.svg').replace(/^\//, '')}`} alt={post.title} loading="lazy" />
            </div>
            <div class="post-card-body">
              <time class="post-card-date">{post.date}</time>
              <h2 class="post-card-title">{post.title}</h2>
              <p class="post-card-summary">{post.summary}</p>
              <span class="post-card-link">阅读全文 →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 120px 0 48px;
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }

  .page-title { font-size: 2.5rem; font-weight: 700; }
  .page-desc { color: var(--color-text-muted); margin-top: 12px; font-size: 1.05rem; }

  .posts-list { display: flex; flex-direction: column; gap: 24px; }

  .post-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }

  .post-card:hover {
    border-color: var(--color-border-light);
    transform: translateY(-3px);
  }

  .post-card-image {
    height: 100%;
    min-height: 180px;
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-card-body {
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-card-date {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin-bottom: 8px;
  }

  .post-card-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 10px;
    line-height: 1.4;
  }

  .post-card-summary {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .post-card-link {
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .post-card { grid-template-columns: 1fr; }
    .post-card-image { height: 200px; }
  }
</style>
